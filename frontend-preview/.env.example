# --- Public site ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only — NEVER expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# Connection strings for the Postgres database.
#  - SUPABASE_DB_URL          → pooled connection (Supavisor, port 6543, transaction mode).
#                               Required for serverless / Vercel — handles thousands of
#                               concurrent functions without exhausting Postgres connections.
#  - SUPABASE_DB_URL_DIRECT   → direct connection (port 5432). Used ONLY for migrations
#                               (`supabase db push`) and long-running admin scripts.
SUPABASE_DB_URL=postgres://postgres.<project-ref>:<password>@aws-0-eu-central-1.pooler.supabase.com:6543/postgres?pgbouncer=true
SUPABASE_DB_URL_DIRECT=postgres://postgres.<project-ref>:<password>@aws-0-eu-central-1.pooler.supabase.com:5432/postgres

# --- Stripe ---
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# --- Email (Resend) ---
RESEND_API_KEY=

# --- Maps ---
NEXT_PUBLIC_GOOGLE_MAPS_KEY=

# --- Optional: Upstash Redis (rate limiting, caching at scale) ---
# Recommended once traffic grows past ~10k MAU. Replaces the in-memory limiter
# in `lib/utils/rate-limit.ts` with a globally-consistent one.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
